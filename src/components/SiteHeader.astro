---
interface NavItem {
	href: string;
	label: string;
}

interface Props {
	pathname: string;
}

const { pathname } = Astro.props as Props;

const navItems: NavItem[] = [
	{ href: '/', label: 'Home' },
	{ href: '/blog/', label: 'Blog' },
	{ href: '/tools/', label: 'Tools' },
	{ href: '/about/', label: 'About' }
];

const isActive = (href: string) =>
	pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="site-header__brand" href="/">THE ARCHIVE</a>
		<nav class="site-header__nav" aria-label="Primary">
			{
				navItems.map((item) => (
					<a class:list={['site-header__link', isActive(item.href) && 'is-active']} href={item.href}>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="site-header__utilities" aria-label="Site actions">
			<button class="site-header__icon-button" type="button" aria-label="Search">
				<img src="/icons/nav-search.svg" alt="" width="17" height="17" loading="lazy" />
			</button>
			<button class="site-header__icon-button" type="button" aria-label="Profile">
				<img src="/icons/nav-profile.svg" alt="" width="19" height="19" loading="lazy" />
			</button>
		</div>
	</div>
</header>
