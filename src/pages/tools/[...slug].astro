---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

interface Props {
	entry: CollectionEntry<'tools'>;
}

export async function getStaticPaths() {
	const tools = await getCollection('tools');

	return tools.map((entry) => ({
		params: { slug: entry.id },
		props: { entry }
	}));
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | Tools`} description={entry.data.description}>
	<article class="article">
		<header class="article-header">
			<p class="meta">
				<span class="status-pill">{entry.data.status}</span> {entry.data.category}
			</p>
			<h1>{entry.data.title}</h1>
			<p>{entry.data.description}</p>
			<div class="action-row">
				{
					entry.data.externalUrl && (
						<a class="button" href={entry.data.externalUrl} target="_blank" rel="noreferrer">Live Tool</a>
					)
				}
				{
					entry.data.repoUrl && (
						<a class="button button-secondary" href={entry.data.repoUrl} target="_blank" rel="noreferrer">
							Source Code
						</a>
					)
				}
			</div>
			{
				entry.data.tags.length > 0 && (
					<ul class="tag-list" aria-label="Tool tags">
						{entry.data.tags.map((tag) => <li>{tag}</li>)}
					</ul>
				)
			}
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
</Layout>
