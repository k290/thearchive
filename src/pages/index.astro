---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/withBase';
---

<Layout
	title="Home | The Cognitive Archive"
	description="A curated space for the curious mind. Exploring the intersections of ancient philosophy, modern psychology, and the velocity of technology."
>
	<div class="home-figma">
		<section class="home-hero">
			<div class="home-hero__content">
				<p class="home-hero__eyebrow">Volume I — Editorial</p>
				<h1 class="home-hero__title">
					<span class="is-primary">THE COGNITIVE</span>
					<span class="is-secondary">ARCHIVE</span>
				</h1>
				<p class="home-hero__lede">
					A curated space for the curious mind. Exploring the intersections of ancient philosophy, modern
					psychology, and the velocity of technology.
				</p>
				<div class="home-hero__actions">
					<a class="button" href={withBase('/blog/')}>Begin Exploration</a>
					<div class="home-hero__divider" aria-hidden="true"></div>
				</div>
			</div>
			<figure class="home-hero__figure">
				<img
					src={withBase('/images/home/hero-book.jpg')}
					alt=""
					width="427"
					height="427"
					loading="eager"
					decoding="async"
				/>
			</figure>
		</section>

		<div class="home-scroll-track" aria-hidden="true">
			<p>Scroll</p>
			<div class="home-scroll-track__line">
				<span class="home-scroll-track__progress"></span>
			</div>
		</div>

		<section class="home-features">
			<article class="home-features__primary">
				<figure class="home-features__primary-image">
					<img
						src={withBase('/images/home/feature-philosophy.jpg')}
						alt=""
						width="664"
						height="415"
						loading="lazy"
						decoding="async"
					/>
				</figure>
				<div class="home-features__primary-content">
					<div class="home-features__meta-row">
						<p>Philosophy</p>
						<p>01.04.24</p>
					</div>
					<h2>
						<a href={withBase('/blog/')}>The Stoic Response to the Digital Acceleration</a>
					</h2>
					<p>How ancient stillness provides the ultimate tool for navigating the relentless stream of modern information.</p>
					<a class="home-features__link" href={withBase('/blog/')}>Read Folio</a>
				</div>
			</article>

			<div class="home-features__right">
				<article class="home-features__secondary">
					<figure class="home-features__secondary-image">
						<img
							src={withBase('/images/home/feature-technology.jpg')}
							alt=""
							width="456"
							height="456"
							loading="lazy"
							decoding="async"
						/>
					</figure>
					<p class="home-features__meta">Technology</p>
					<h3>
						<a href={withBase('/blog/')}>Ethics of Autonomous Intelligence</a>
					</h3>
					<div class="home-features__secondary-divider" aria-hidden="true"></div>
				</article>

				<article class="home-features__tool">
					<p class="home-features__meta">Tools</p>
					<h3>
						<a href={withBase('/tools/')}>The Cognitive Workbench</a>
					</h3>
					<p>A repository of mental models and frameworks for structural thinking in an unstructured world.</p>
					<div class="home-features__tool-footer">
						<img src={withBase('/images/home/repository-mark.svg')} alt="" width="13" height="22" loading="lazy" />
						<a href={withBase('/tools/')}>Access Repository</a>
					</div>
				</article>
			</div>
		</section>

		<section class="home-psychology">
			<div class="home-psychology__inner">
				<div class="home-psychology__content">
					<h2>
						The Psychology of
						<span>Curation</span>
					</h2>
					<p>
						In an era of infinite abundance, the act of choosing is the ultimate form of rebellion. We explore
						why the human psyche craves order amidst digital chaos.
					</p>
					<ol>
						<li>
							<span>01</span>
							<span>The Paradox of Choice</span>
						</li>
						<li>
							<span>02</span>
							<span>Visual Serenity &amp; Cognitive Load</span>
						</li>
						<li>
							<span>03</span>
							<span>The Digital Monasticism</span>
						</li>
					</ol>
				</div>
				<figure class="home-psychology__figure">
					<img
						src={withBase('/images/home/psychology-light.jpg')}
						alt=""
						width="512"
						height="544"
						loading="lazy"
						decoding="async"
					/>
				</figure>
			</div>
		</section>
	</div>
</Layout>
